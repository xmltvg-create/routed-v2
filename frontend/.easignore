# .easignore — files NOT uploaded to EAS Build.
# Supersedes .gitignore when present.
# Mirrors .gitignore but also excludes caches/temp files that can harbour the
# kind of zero-byte garbage-named files that broke a previous build.

# Dependencies (EAS runs yarn install on their side — never ship)
node_modules/

# Expo / Metro caches (largest source of transient junk files)
.expo/
.expo-shared/
.metro-cache/
.metro-health-check*

# Python / tooling caches that sometimes leak into /app/frontend
.ruff_cache/
__pycache__/
*.pyc

# Build outputs (regenerated by EAS)
dist/
dist-*/
web-build/
android/build/
ios/build/
android/app/build/

# Native signing / secrets (never upload)
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# Editor / OS cruft
.DS_Store
Thumbs.db
*.swp
*.swo
*.orig.*
.kotlin/

# Logs & temp
*.log
*.tmp
npm-debug.*
yarn-debug.*
yarn-error.*

# Local env overrides (kept — EAS has its own env)
.env*.local

# TypeScript build artefacts
*.tsbuildinfo
expo-env.d.ts

# Reset-project backup directory
app-example/

# Git / internal state
.git/
.github/
