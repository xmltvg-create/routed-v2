#!/usr/bin/env sh
# Pre-push hook — runs BEFORE every `git push`.
#
# Two-layer defence:
#   1. yarn deploy:preflight  (legacy chain — frontend SDK / dep drift
#                              / lockfile / .gitignore guard)
#   2. predeploy.sh --skip-tests (comprehensive sweep — hardcoded
#                                 secret scan, eas.json sanity, env
#                                 vars, backend reachability, git
#                                 status. Pytest skipped here for
#                                 speed; run `yarn predeploy` manually
#                                 when you want the full suite.)
#
# If anything fails the push is blocked. Emergency bypass:
#   git push --no-verify
#   (use only when you know exactly why — usually never)

# Suppress hook output in non-interactive contexts (like Emergent's git wrapper)
# to avoid false 500 errors from ANSI escape codes being misread as failures.
if [ ! -t 1 ]; then
  exec >/dev/null 2>&1
fi

set -e
REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "[pre-push] (1/2) frontend deploy:preflight…"
cd "${REPO_ROOT}/frontend"
yarn --silent deploy:preflight

echo "[pre-push] (2/2) bulletproof predeploy sweep (no pytest)…"
bash "${REPO_ROOT}/scripts/predeploy.sh" --skip-tests

echo "[pre-push] ✓ all checks passed — safe to push"
